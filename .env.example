# ---- Qwen Cloud (Alibaba Cloud Model Studio / DashScope, OpenAI-compatible) ----
# Get your key at https://qwencloud.com  (apply for the $40 hackathon voucher too)
QWEN_API_KEY=sk-your-key-here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Models
QWEN_CHAT_MODEL=qwen-plus
QWEN_CHEAP_MODEL=qwen-turbo
QWEN_EMBED_MODEL=text-embedding-v4
EMBED_DIM=1024

# ---- Database (PostgreSQL + pgvector) ----
# Local dev: the db container publishes on host port 5433 (5432 is often taken).
# (Inside docker-compose the app reaches the db on 5432 via the compose network.)
DATABASE_URL=postgresql+psycopg://mnemo:mnemo@localhost:5433/mnemo

# ---- Memory tuning ----
# Time constant (days) for the recency / forgetting curve
DECAY_TAU_DAYS=14
# Memories whose decay score falls below this are archived by the forget sweep
FORGET_THRESHOLD=0.15
# Cosine similarity above which two memories are candidates for consolidation
CONSOLIDATE_SIMILARITY=0.86
# Default token budget for a recall (context-window-aware selection)
DEFAULT_TOKEN_BUDGET=1200
